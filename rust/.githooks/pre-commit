#!/bin/bash
# Pre-commit hook: run clippy and fmt checks before committing.
# Install: cd rust && git config core.hooksPath .githooks

set -e

echo "Running cargo fmt check..."
cargo fmt --all -- --check
if [ $? -ne 0 ]; then
    echo "❌ cargo fmt failed. Run 'cargo fmt' to fix."
    exit 1
fi

echo "Running cargo clippy..."
cargo clippy --all-targets --all-features -- -D warnings
if [ $? -ne 0 ]; then
    echo "❌ clippy found issues. Fix them before committing."
    exit 1
fi

echo "✅ Pre-commit checks passed."
