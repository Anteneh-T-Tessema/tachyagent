{
  "name": "tachy-autocomplete",
  "displayName": "Tachy Autocomplete",
  "description": "AI-powered inline code completions from your local Tachy agent",
  "version": "0.1.0",
  "publisher": "tachy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Anteneh-T-Tessema/tachyagent"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Tachy Autocomplete",
      "properties": {
        "tachy.endpoint": {
          "type": "string",
          "default": "http://localhost:7777",
          "description": "Tachy daemon URL"
        },
        "tachy.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the Tachy daemon (optional)"
        },
        "tachy.model": {
          "type": "string",
          "default": "gemma4:26b",
          "description": "LLM model for completions"
        },
        "tachy.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable Tachy inline completions"
        },
        "tachy.maxTokens": {
          "type": "number",
          "default": 128,
          "description": "Maximum tokens per completion"
        },
        "tachy.debounceMs": {
          "type": "number",
          "default": 300,
          "description": "Debounce delay in milliseconds before requesting completion"
        }
      }
    },
    "commands": [
      {
        "command": "tachy.toggleAutocomplete",
        "title": "Tachy: Toggle Autocomplete"
      },
      {
        "command": "tachy.checkHealth",
        "title": "Tachy: Check Daemon Health"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
