{
  "name": "tachy-autocomplete",
  "displayName": "Tachy Autocomplete",
  "description": "AI-powered inline code completions from your local Tachy agent",
  "version": "0.1.0",
  "publisher": "tachy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Anteneh-T-Tessema/tachyagent"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tachy",
          "title": "Tachy",
          "icon": "$(zap)"
        }
      ]
    },
    "views": {
      "tachy": [
        {
          "type": "webview",
          "id": "tachy.chatView",
          "name": "Chat",
          "icon": "$(comment-discussion)",
          "contextualTitle": "Tachy Chat"
        },
        {
          "id": "tachy.dagView",
          "name": "Execution DAG",
          "icon": "$(type-hierarchy)"
        },
        {
          "id": "tachy.auditView",
          "name": "Audit Trail",
          "icon": "$(shield)"
        }
      ]
    },
    "configuration": {
      "title": "Tachy",
      "properties": {
        "tachy.endpoint": {
          "type": "string",
          "default": "http://localhost:7777",
          "description": "Tachy daemon URL"
        },
        "tachy.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for the Tachy daemon (optional)"
        },
        "tachy.model": {
          "type": "string",
          "default": "gemma4:26b",
          "description": "LLM model for completions and chat"
        },
        "tachy.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable Tachy inline completions"
        },
        "tachy.maxTokens": {
          "type": "number",
          "default": 128,
          "description": "Maximum tokens per completion"
        },
        "tachy.debounceMs": {
          "type": "number",
          "default": 300,
          "description": "Debounce delay in milliseconds before requesting completion"
        },
        "tachy.pollIntervalMs": {
          "type": "number",
          "default": 3000,
          "description": "Polling interval for DAG and audit updates (ms)"
        },
        "tachy.showPolicyWarningsInline": {
          "type": "boolean",
          "default": true,
          "description": "Show policy violations as VS Code diagnostics"
        }
      }
    },
    "commands": [
      {
        "command": "tachy.toggleAutocomplete",
        "title": "Tachy: Toggle Autocomplete"
      },
      {
        "command": "tachy.checkHealth",
        "title": "Tachy: Check Daemon Health"
      },
      {
        "command": "tachy.selectModel",
        "title": "Tachy: Select Model",
        "icon": "$(zap)"
      },
      {
        "command": "tachy.explainSelection",
        "title": "Tachy: Explain Selection"
      },
      {
        "command": "tachy.fixSelection",
        "title": "Tachy: Fix Selection"
      },
      {
        "command": "tachy.fixDiagnostic",
        "title": "⚡ Fix with Tachy"
      },
      {
        "command": "tachy.runSwarm",
        "title": "Tachy: Run Swarm Refactor on Open Files"
      },
      {
        "command": "tachy.validatePolicy",
        "title": "Tachy: Validate Policy"
      },
      {
        "command": "tachy.openDashboard",
        "title": "Tachy: Open Web Dashboard"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "tachy.explainSelection",
          "when": "editorHasSelection",
          "group": "tachy@1"
        },
        {
          "command": "tachy.fixSelection",
          "when": "editorHasSelection",
          "group": "tachy@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "tachy.explainSelection",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      },
      {
        "command": "tachy.fixSelection",
        "key": "ctrl+shift+f",
        "mac": "cmd+shift+f",
        "when": "editorHasSelection"
      },
      {
        "command": "tachy.selectModel",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      },
      {
        "command": "tachy.runSwarm",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
